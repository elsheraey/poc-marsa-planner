# Copy to .env and fill in for docker-compose. Never commit .env.

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-me-to-a-64-byte-random-secret

POSTGRES_PASSWORD=marsa

# Runtime
APP_ENV=production
LOG_LEVEL=INFO
ACCESS_TOKEN_EXPIRE_MINUTES=60
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
CORS_ORIGINS=http://localhost:8080

RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_DEFAULT=120/minute

WEB_PORT=8080
