# Copy to .env and fill in real values. Never commit .env.

# App
APP_ENV=development
LOG_LEVEL=INFO

# Database (Postgres in prod, SQLite fine for local dev)
DATABASE_URL=postgresql+psycopg://marsa:marsa@localhost:5432/marsa
# DATABASE_URL=sqlite:///./marsa.db

# Auth — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-me-generate-a-real-64-byte-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Cookies
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173

# Rate limiting
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_DEFAULT=120/minute

# Simulation data directory
DATA_DIR=./data
